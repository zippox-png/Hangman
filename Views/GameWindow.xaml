<Window x:Class="Hangman.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hangman Game" Height="620" Width="820"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="LetterBtn">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Game" Command="{Binding NewGameCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open Game" Command="{Binding OpenGameCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save Game" Command="{Binding SaveGameCommand}" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="Statistics" Click="ShowStatistics_Click"/>
                <Separator/>
                <MenuItem Header="_Cancel" Command="{Binding CancelCommand}" InputGestureText="Ctrl+Q"/>
            </MenuItem>
            <MenuItem Header="_Categories" x:Name="CategoriesMenu"/>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Click="ShowAbout_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.RowSpan="4" Margin="0,0,12,0">
                <Border Height="50" Width="50" CornerRadius="25" ClipToBounds="True" Margin="0,0,0,4" HorizontalAlignment="Left">
                    <Image Source="{Binding UserAvatarPath}" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="{Binding UserDisplayName}" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                <Border BorderBrush="Gray" BorderThickness="1" Height="220" Width="180">
                    <Image Source="{Binding HangmanImagePath}" Stretch="Uniform"/>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Erori: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding WrongGuesses}"/>
                    <TextBlock Text="/"/>
                    <TextBlock Text="{Binding MaxWrong}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Timp: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding TimeDisplay}" Foreground="Red" FontSize="16"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Nivel: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentLevel}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Wins consecutive: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding ConsecutiveWins}"/>
                    <TextBlock Text="/3"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{Binding SelectedCategory}" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding WordDisplayText}"
                           FontSize="28" FontFamily="Courier New"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Padding="4,0"/>  
            </StackPanel>
            <ItemsControl Grid.Column="1" Grid.Row="1"
              ItemsSource="{Binding LetterButtons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource LetterBtn}"
                    Content="{Binding Letter}"
                    IsEnabled="{Binding IsEnabled}"
                    Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Letter}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Column="1" Grid.Row="2"
                       Text="{Binding StatusMessage}"
                       FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </Grid>
    </DockPanel>
</Window>
